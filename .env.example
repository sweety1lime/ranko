# Строка подключения к Postgres (Neon).
# Neon dashboard → твой проект → Connection Details → выбери "Pooled connection".
# Формат: postgresql://USER:PASSWORD@HOST/DB?sslmode=require
# Локально: скопируй этот файл в .env.local и подставь свою строку (в .gitignore, не коммитится).
DATABASE_URL=

# Публичный адрес сайта — из него собираются абсолютные ссылки на OG-превью.
# Не задан: на Vercel берётся VERCEL_URL, локально — http://localhost:3000.
NEXT_PUBLIC_SITE_URL=

# Rate limit на создание решений — опционально.
# Обе переменные пусты: лимит считается в памяти процесса (на Vercel у каждого инстанса своя,
# поэтому лимит дырявый — годится локально и для превью).
# Обе заданы: лимит считается в Upstash Redis, общо для всех инстансов — так и надо в проде.
# Upstash console → Redis database → REST API → скопируй URL и токен.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
